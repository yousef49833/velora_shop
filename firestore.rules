rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: users
    // Fields: uid, displayName, email, photoURL, role, createdAt, addresses
    //
    // Collection: vendors
    // Fields: uid, storeName, description, logoURL, status, rating, createdAt
    //
    // Collection: products
    // Fields: name, description, price, currency, category, brand, images, vendorId, stock, specifications, rating, reviewCount, discount, createdAt
    //
    // Collection: orders
    // Fields: customerId, items, totalAmount, currency, status, paymentMethod, shippingAddress, createdAt
    //
    // Collection: reviews
    // Fields: productId, customerId, customerName, rating, comment, createdAt
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "mono.443471@gmail.com" && request.auth.token.email_verified == true));
    }

    function isVendor() {
      return isAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'vendor';
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role']) &&
             data.uid is string &&
             data.email is string &&
             data.role in ['customer', 'admin', 'vendor'];
    }

    function isValidProduct(data) {
      return data.keys().hasAll(['name', 'price', 'vendorId', 'category']) &&
             data.name is string && data.name.size() < 200 &&
             data.price is number && data.price >= 0 &&
             data.vendorId is string &&
             data.category is string;
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isValidUser(request.resource.data) && (isOwner(userId) || isAdmin());
      allow update: if isAuthenticated() && isValidUser(request.resource.data) && (isOwner(userId) || isAdmin());
    }

    match /vendors/{vendorId} {
      allow read: if true;
      allow create: if isAuthenticated() && (isOwner(vendorId) || isAdmin());
      allow update: if isAuthenticated() && (isOwner(vendorId) || isAdmin());
    }

    match /products/{productId} {
      allow read: if true;
      allow create: if isVendor() || isAdmin();
      allow update: if (isVendor() && resource.data.vendorId == request.auth.uid) || isAdmin();
      allow delete: if (isVendor() && resource.data.vendorId == request.auth.uid) || isAdmin();

      match /reviews/{reviewId} {
        allow read: if true;
        allow create: if isAuthenticated();
        allow update: if isAuthenticated() && resource.data.customerId == request.auth.uid;
      }
    }

    match /orders/{orderId} {
      allow read: if isAuthenticated() && (resource.data.customerId == request.auth.uid || isAdmin() || (isVendor() && resource.data.items[0].vendorId == request.auth.uid));
      allow create: if isAuthenticated() && request.resource.data.customerId == request.auth.uid;
      allow update: if isAdmin() || (isVendor() && resource.data.items[0].vendorId == request.auth.uid);
    }

    match /payouts/{payoutId} {
      allow read: if isAdmin() || (isVendor() && resource.data.vendorId == request.auth.uid);
      allow create, update: if isAdmin();
    }

    match /users/{userId}/wishlist/{wishlistId} {
      allow read, write: if isOwner(userId);
    }
  }
}
